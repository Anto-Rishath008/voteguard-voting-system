{
  "name": "voteguard-voting-system",
  "version": "2.0.0",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "env": {
    "DATABASE_URL": {
      "description": "PostgreSQL connection string for Supabase database",
      "required": true
    },
    "JWT_SECRET": {
      "description": "Secret key for JWT token signing",
      "required": true
    },
    "NEXTAUTH_URL": {
      "description": "Full URL of the deployed application",
      "required": true
    },
    "NEXTAUTH_SECRET": {
      "description": "Secret for NextAuth.js sessions",
      "required": true
    }
  },
  "functions": {
    "pages/api/**/*.js": {
      "maxDuration": 30
    }
  },
  "regions": ["iad1"],
  "builds": [
    {
      "src": "next.config.ts",
      "use": "@vercel/next"
    }
  ]
}